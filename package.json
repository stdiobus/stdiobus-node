{
  "name": "@stdiobus/node",
  "version": "1.0.1",
  "description": "Native Node.js binding for stdio_bus - AI agent transport layer. No external binary required.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./docker": {
      "require": "./lib/docker-backend.js",
      "import": "./lib/docker-backend.js"
    }
  },
  "homepage": "https://github.com/stdiobus/stdiobus-node",
  "bugs": {
    "url": "https://github.com/stdiobus/stdiobus-node/issues"
  },
  "scripts": {
    "install": "node lib/load-native.js --check || node-gyp rebuild",
    "build": "node-gyp rebuild",
    "build:debug": "node-gyp rebuild --debug",
    "prebuild": "./scripts/build-prebuilds.sh",
    "prepublishOnly": "npm run prebuild",
    "test": "node test/basic.js",
    "test:docker": "node test/docker-backend.js",
    "test:conformance": "node test/conformance.js",
    "test:all": "npm test && npm run test:conformance",
    "clean": "node-gyp clean"
  },
  "keywords": [
    "stdio-bus",
    "stdiobus",
    "acp",
    "mcp",
    "agent",
    "ai",
    "llm",
    "transport",
    "native",
    "napi",
    "json-rpc",
    "ndjson",
    "ipc"
  ],
  "author": "Raman Marozau <raman@worktif.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stdiobus/stdiobus-node.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "lib/",
    "src/",
    "prebuilds/",
    "binding.gyp",
    "LICENSE",
    "README.md"
  ],
  "gypfile": true
}
