{
  "name": "@stdiobus/node",
  "version": "2.1.1",
  "description": "Native Node.js binding for stdio_bus — AI agent transport layer. Prebuild binaries, Docker fallback.",
  "main": "out/dist/index.js",
  "types": "out/tsc/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/tsc/index.d.ts",
      "require": "./out/dist/index.js",
      "default": "./out/dist/index.js"
    }
  },
  "scripts": {
    "build:js": "node scripts/esbuild.config.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf out",
    "test": "node test/basic.js",
    "test:docker": "node test/docker-backend.js",
    "test:conformance": "node test/conformance.js",
    "test:e2e": "./test/e2e/pack-and-test.sh",
    "test:e2e:native": "./test/e2e/pack-and-test.sh --skip-docker",
    "test:e2e:docker": "./test/e2e/pack-and-test.sh --skip-native",
    "test:readme": "npx tsx test/readme/verbatim.test.ts",
    "test:all": "npm test && npm run test:conformance && npm run test:readme",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "stdio-bus",
    "stdiobus",
    "acp",
    "mcp",
    "agent",
    "ai",
    "llm",
    "transport",
    "native",
    "napi",
    "json-rpc",
    "ndjson",
    "ipc"
  ],
  "author": "Raman Marozau <raman@worktif.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stdiobus/stdiobus-node.git"
  },
  "homepage": "https://github.com/stdiobus/stdiobus-node",
  "bugs": {
    "url": "https://github.com/stdiobus/stdiobus-node/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "out/dist/**/*.js",
    "out/tsc/**/*.d.ts",
    "prebuilds/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@stdiobus/mcp-agentic": "1.1.2",
    "@types/node": "^20.19.39",
    "esbuild": "^0.25.0",
    "openai": "^6.35.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
